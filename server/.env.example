# --- BigQuery ---
GOOGLE_CLOUD_PROJECT=drivn-project-1
BQ_LOCATION=US
# Fully-qualified dataset holding the materialized-view layer (reads _fact_trips here).
BQ_KPI_DATASET_FQ=drivn-project-1.dashboard_kpis
# Catalog (scheduled-departures) view for trip COUNTS. Defaults to
# <BQ_KPI_DATASET_FQ>.v_catalog_trips (created by sql/operator_report_views.sql).
# BQ_CATALOG_FQ=drivn-project-1.dashboard_kpis.v_catalog_trips
# Per-query cost guardrail (bytes). _fact_trips is tiny; this just fails runaway scans.
BQ_MAX_BYTES_BILLED=2000000000
# Locally, leave unset to use ADC (gcloud auth application-default login).
# On Cloud Run, point at a read-only service-account key (bigquery.dataViewer + jobUser).
# GOOGLE_APPLICATION_CREDENTIALS=./sa-key.json

# --- Server ---
PORT=8788
CACHE_TTL_MS=600000
LOG_LEVEL=info
# Comma-separated allow-list of frontend origins (prod). Leave unset in dev
# (the Vite proxy makes /api same-origin, so CORS isn't exercised).
# CORS_ORIGINS=https://your-report-app.example.com
